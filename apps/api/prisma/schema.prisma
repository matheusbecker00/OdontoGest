generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  LOCKED
  DISABLED
}

enum ClinicStatus {
  ACTIVE
  READ_ONLY
  SUSPENDED
  CLOSED
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REVOKED
}

enum RoleCode {
  OWNER
  ADMIN
  DENTIST
  RECEPTIONIST
  FINANCE
}

enum SessionStatus {
  ACTIVE
  ROTATED
  REVOKED
  EXPIRED
}

enum AuditOutcome {
  SUCCESS
  DENIED
  FAILURE
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
}

model User {
  id                  String     @id @default(uuid()) @db.Uuid
  name                String     @db.VarChar(160)
  email               String     @db.VarChar(320)
  emailCanonical      String     @unique(map: "user_email_canonical_key") @map("email_canonical") @db.VarChar(320)
  firebaseUid         String?    @unique(map: "user_firebase_uid_key") @map("firebase_uid") @db.VarChar(128)
  passwordHash        String     @map("password_hash") @db.VarChar(255)
  passwordHashVersion Int        @default(1) @map("password_hash_version")
  status              UserStatus @default(PENDING_VERIFICATION)
  emailVerifiedAt     DateTime?  @map("email_verified_at") @db.Timestamptz(3)
  failedLoginCount    Int        @default(0) @map("failed_login_count")
  lockedUntil         DateTime?  @map("locked_until") @db.Timestamptz(3)
  sessionVersion      Int        @default(1) @map("session_version")
  lastLoginAt         DateTime?  @map("last_login_at") @db.Timestamptz(3)
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt           DateTime?  @map("deleted_at") @db.Timestamptz(3)

  memberships             ClinicMembership[]
  refreshSessions         RefreshSession[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  auditLogs               AuditLog[]               @relation("AuditActor")
  securityEvents          SecurityEvent[]
  termsAcceptances        TermsAcceptance[]

  @@map("users")
}

model Clinic {
  id        String       @id @default(uuid()) @db.Uuid
  legalName String       @map("legal_name") @db.VarChar(180)
  tradeName String       @map("trade_name") @db.VarChar(180)
  status    ClinicStatus @default(ACTIVE)
  timezone  String       @default("America/Sao_Paulo") @db.VarChar(80)
  locale    String       @default("pt-BR") @db.VarChar(16)
  currency  String       @default("BRL") @db.Char(3)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime?    @map("deleted_at") @db.Timestamptz(3)

  memberships      ClinicMembership[]
  settings         ClinicSettings?
  refreshSessions  RefreshSession[]
  auditLogs        AuditLog[]
  termsAcceptances TermsAcceptance[]
  outboxEvents     OutboxEvent[]

  @@index([status, createdAt], map: "clinic_status_created_idx")
  @@map("clinics")
}

model ClinicSettings {
  id                        String   @id @default(uuid()) @db.Uuid
  clinicId                  String   @unique(map: "clinic_settings_clinic_key") @map("clinic_id") @db.Uuid
  defaultAppointmentMinutes Int      @default(30) @map("default_appointment_minutes")
  gracePeriodDays           Int      @default(7) @map("grace_period_days")
  version                   Int      @default(1)
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                 DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy                 String?  @map("created_by") @db.Uuid
  updatedBy                 String?  @map("updated_by") @db.Uuid

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Restrict)

  @@map("clinic_settings")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  code        RoleCode @unique
  name        String   @db.VarChar(80)
  description String   @db.VarChar(240)
  isSystem    Boolean  @default(true) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  memberships ClinicMembership[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(100)
  description String   @db.VarChar(240)
  riskLevel   Int      @default(1) @map("risk_level")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model ClinicMembership {
  id                   String           @id @default(uuid()) @db.Uuid
  clinicId             String           @map("clinic_id") @db.Uuid
  userId               String           @map("user_id") @db.Uuid
  roleId               String           @map("role_id") @db.Uuid
  status               MembershipStatus @default(INVITED)
  authorizationVersion Int              @default(1) @map("authorization_version")
  invitedBy            String?          @map("invited_by") @db.Uuid
  invitedAt            DateTime?        @map("invited_at") @db.Timestamptz(3)
  acceptedAt           DateTime?        @map("accepted_at") @db.Timestamptz(3)
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt            DateTime?        @map("deleted_at") @db.Timestamptz(3)

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([clinicId, userId], map: "membership_clinic_user_key")
  @@index([userId, status, clinicId], map: "membership_user_status_clinic_idx")
  @@index([clinicId, status, roleId], map: "membership_clinic_status_role_idx")
  @@map("clinic_memberships")
}

model RefreshSession {
  id                  String        @id @default(uuid()) @db.Uuid
  userId              String        @map("user_id") @db.Uuid
  activeClinicId      String?       @map("active_clinic_id") @db.Uuid
  familyId            String        @map("family_id") @db.Uuid
  parentSessionId     String?       @map("parent_session_id") @db.Uuid
  replacedBySessionId String?       @map("replaced_by_session_id") @db.Uuid
  tokenHash           String        @unique(map: "refresh_session_token_hash_key") @map("token_hash") @db.Char(64)
  status              SessionStatus @default(ACTIVE)
  issuedAt            DateTime      @default(now()) @map("issued_at") @db.Timestamptz(3)
  lastUsedAt          DateTime?     @map("last_used_at") @db.Timestamptz(3)
  idleExpiresAt       DateTime      @map("idle_expires_at") @db.Timestamptz(3)
  absoluteExpiresAt   DateTime      @map("absolute_expires_at") @db.Timestamptz(3)
  revokedAt           DateTime?     @map("revoked_at") @db.Timestamptz(3)
  revokeReason        String?       @map("revoke_reason") @db.VarChar(120)
  ipPrefix            String?       @map("ip_prefix") @db.VarChar(64)
  userAgentSummary    String?       @map("user_agent_summary") @db.VarChar(255)
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)

  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeClinic Clinic? @relation(fields: [activeClinicId], references: [id], onDelete: SetNull)

  @@index([userId, status, absoluteExpiresAt], map: "refresh_session_user_status_exp_idx")
  @@index([familyId, status, issuedAt], map: "refresh_session_family_status_idx")
  @@map("refresh_sessions")
}

model EmailVerificationToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  tokenHash    String    @unique(map: "email_verification_token_hash_key") @map("token_hash") @db.Char(64)
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(3)
  consumedAt   DateTime? @map("consumed_at") @db.Timestamptz(3)
  attemptCount Int       @default(0) @map("attempt_count")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt], map: "email_verification_user_exp_idx")
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  tokenHash    String    @unique(map: "password_reset_token_hash_key") @map("token_hash") @db.Char(64)
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(3)
  consumedAt   DateTime? @map("consumed_at") @db.Timestamptz(3)
  attemptCount Int       @default(0) @map("attempt_count")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt], map: "password_reset_user_exp_idx")
  @@map("password_reset_tokens")
}

model TermsAcceptance {
  id               String   @id @default(uuid()) @db.Uuid
  clinicId         String   @map("clinic_id") @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  documentType     String   @map("document_type") @db.VarChar(40)
  documentVersion  String   @map("document_version") @db.VarChar(40)
  acceptedAt       DateTime @default(now()) @map("accepted_at") @db.Timestamptz(3)
  ipPrefix         String?  @map("ip_prefix") @db.VarChar(64)
  userAgentSummary String?  @map("user_agent_summary") @db.VarChar(255)
  evidenceDigest   String   @map("evidence_digest") @db.Char(64)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([clinicId, userId, documentType, documentVersion], map: "terms_acceptance_version_key")
  @@index([clinicId, acceptedAt], map: "terms_acceptance_clinic_date_idx")
  @@map("terms_acceptances")
}

model AuditLog {
  id               String       @id @default(uuid()) @db.Uuid
  clinicId         String       @map("clinic_id") @db.Uuid
  actorUserId      String?      @map("actor_user_id") @db.Uuid
  action           String       @db.VarChar(100)
  entityType       String       @map("entity_type") @db.VarChar(80)
  entityId         String?      @map("entity_id") @db.Uuid
  outcome          AuditOutcome
  requestId        String       @map("request_id") @db.VarChar(80)
  ipPrefix         String?      @map("ip_prefix") @db.VarChar(64)
  userAgentSummary String?      @map("user_agent_summary") @db.VarChar(255)
  beforeRedacted   Json?        @map("before_redacted")
  afterRedacted    Json?        @map("after_redacted")
  metadataRedacted Json?        @map("metadata_redacted")
  occurredAt       DateTime     @default(now()) @map("occurred_at") @db.Timestamptz(3)
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  actor  User?  @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([clinicId, occurredAt, id], map: "audit_clinic_date_idx")
  @@index([clinicId, actorUserId, occurredAt], map: "audit_clinic_actor_date_idx")
  @@index([clinicId, entityType, entityId], map: "audit_clinic_entity_idx")
  @@map("audit_logs")
}

model SecurityEvent {
  id               String       @id @default(uuid()) @db.Uuid
  userId           String?      @map("user_id") @db.Uuid
  action           String       @db.VarChar(100)
  outcome          AuditOutcome
  requestId        String       @map("request_id") @db.VarChar(80)
  ipPrefix         String?      @map("ip_prefix") @db.VarChar(64)
  userAgentSummary String?      @map("user_agent_summary") @db.VarChar(255)
  metadataRedacted Json?        @map("metadata_redacted")
  occurredAt       DateTime     @default(now()) @map("occurred_at") @db.Timestamptz(3)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([occurredAt, action], map: "security_event_date_action_idx")
  @@index([userId, occurredAt], map: "security_event_user_date_idx")
  @@map("security_events")
}

model OutboxEvent {
  id               String       @id @default(uuid()) @db.Uuid
  clinicId         String?      @map("clinic_id") @db.Uuid
  aggregateType    String       @map("aggregate_type") @db.VarChar(80)
  aggregateId      String       @map("aggregate_id") @db.Uuid
  eventType        String       @map("event_type") @db.VarChar(100)
  payloadMinimized Json         @map("payload_minimized")
  status           OutboxStatus @default(PENDING)
  occurredAt       DateTime     @default(now()) @map("occurred_at") @db.Timestamptz(3)
  publishedAt      DateTime?    @map("published_at") @db.Timestamptz(3)
  attemptCount     Int          @default(0) @map("attempt_count")
  nextAttemptAt    DateTime?    @map("next_attempt_at") @db.Timestamptz(3)
  lastErrorCode    String?      @map("last_error_code") @db.VarChar(80)
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  clinic Clinic? @relation(fields: [clinicId], references: [id], onDelete: Restrict)

  @@index([status, nextAttemptAt, occurredAt], map: "outbox_status_attempt_idx")
  @@index([clinicId, occurredAt], map: "outbox_clinic_date_idx")
  @@map("outbox_events")
}
