rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /clinics/{clinicId}/members/{memberId} {
      allow read: if isClinicMember(clinicId);
      allow create: if isOwnerBootstrap(clinicId, memberId)
        || (isClinicAdmin(clinicId) && isValidTeamMember(clinicId, memberId));
      allow update: if (
          isClinicAdmin(clinicId)
          && memberId != request.auth.uid
          && isValidTeamMember(clinicId, memberId)
        )
        || isOwnerSelfRefresh(clinicId, memberId);
      allow delete: if false;
    }

    match /clinics/{clinicId}/invites/{inviteId} {
      allow read: if isClinicMember(clinicId);
      allow create, update: if isClinicAdmin(clinicId) && isValidTeamInvite(clinicId);
      allow delete: if false;
    }

    match /clinics/{clinicId}/settings/{settingsId} {
      allow read: if isClinicMember(clinicId);
      allow create, update: if isClinicAdmin(clinicId)
        && settingsId == 'profile'
        && isValidSharedClinicSettings(clinicId);
      allow delete: if false;
    }

    match /clinics/{clinicId}/billing/{billingId} {
      allow read: if isClinicMember(clinicId);
      allow create, update, delete: if false;
    }

    match /clinics/{clinicId}/appointments/{appointmentId} {
      allow read: if isClinicMember(clinicId);
      allow create: if hasClinicRole(clinicId, ['OWNER', 'ADMIN', 'RECEPTIONIST', 'DENTIST'])
        && request.resource.data.userId == request.auth.uid
        && isValidSharedAppointment(clinicId);
      allow update: if hasClinicRole(clinicId, ['OWNER', 'ADMIN', 'RECEPTIONIST', 'DENTIST'])
        && isValidSharedAppointment(clinicId);
      allow delete: if false;
    }

    match /clinics/{clinicId}/finance/{entryId} {
      allow read: if hasClinicRole(clinicId, ['OWNER', 'ADMIN']);
      allow create: if hasClinicRole(clinicId, ['OWNER', 'ADMIN'])
        && request.resource.data.userId == request.auth.uid
        && isValidSharedFinancialEntry(clinicId);
      allow update: if hasClinicRole(clinicId, ['OWNER', 'ADMIN'])
        && isValidSharedFinancialEntry(clinicId);
      allow delete: if false;
    }

    match /clinics/{clinicId}/inventory/{itemId} {
      allow read: if hasClinicRole(clinicId, ['OWNER', 'ADMIN']);
      allow create: if hasClinicRole(clinicId, ['OWNER', 'ADMIN'])
        && request.resource.data.userId == request.auth.uid
        && isValidSharedInventoryItem(clinicId);
      allow update: if hasClinicRole(clinicId, ['OWNER', 'ADMIN'])
        && isValidSharedInventoryItem(clinicId);
      allow delete: if false;
    }

    match /users/{userId}/clinics/{clinicId}/appointments/{appointmentId} {
      allow read: if isOwnerUser(userId);
      allow create, update: if isOwnerUser(userId) && isValidAppointment(userId, clinicId);
      allow delete: if false;
    }

    match /users/{userId}/clinics/{clinicId}/finance/{entryId} {
      allow read: if isOwnerUser(userId);
      allow create, update: if isOwnerUser(userId) && isValidFinancialEntry(userId, clinicId);
      allow delete: if false;
    }

    match /users/{userId}/clinics/{clinicId}/inventory/{itemId} {
      allow read: if isOwnerUser(userId);
      allow create, update: if isOwnerUser(userId) && isValidInventoryItem(userId, clinicId);
      allow delete: if false;
    }

    match /users/{userId}/clinics/{clinicId}/settings/{settingsId} {
      allow read: if isOwnerUser(userId);
      allow create, update: if isOwnerUser(userId)
        && settingsId == 'profile'
        && isValidClinicSettings(userId, clinicId);
      allow delete: if false;
    }

    function isOwnerUser(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isClinicMember(clinicId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/clinics/$(clinicId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/clinics/$(clinicId)/members/$(request.auth.uid)).data.status == 'ACTIVE';
    }

    function isClinicAdmin(clinicId) {
      return isClinicMember(clinicId)
        && get(/databases/$(database)/documents/clinics/$(clinicId)/members/$(request.auth.uid)).data.role in [
          'OWNER',
          'ADMIN'
        ];
    }

    function hasClinicRole(clinicId, roles) {
      return isClinicMember(clinicId)
        && get(/databases/$(database)/documents/clinics/$(clinicId)/members/$(request.auth.uid)).data.role in roles;
    }

    function isOwnerBootstrap(clinicId, memberId) {
      return request.auth != null
        && memberId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.clinicId == clinicId
        && request.resource.data.role == 'OWNER'
        && isValidTeamMember(clinicId, memberId);
    }

    function isOwnerSelfRefresh(clinicId, memberId) {
      return request.auth != null
        && memberId == request.auth.uid
        && resource.data.role == 'OWNER'
        && request.resource.data.role == 'OWNER'
        && isValidTeamMember(clinicId, memberId);
    }

    function isValidAppointment(userId, clinicId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'clinicId',
          'userId',
          'date',
          'startTime',
          'durationMinutes',
          'patientName',
          'dentistName',
          'procedureName',
          'status',
          'notes',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id is string
        && request.resource.data.clinicId == clinicId
        && request.resource.data.userId == userId
        && request.resource.data.date is string
        && request.resource.data.startTime is string
        && request.resource.data.durationMinutes is int
        && request.resource.data.durationMinutes >= 10
        && request.resource.data.durationMinutes <= 480
        && request.resource.data.patientName is string
        && request.resource.data.patientName.size() > 0
        && request.resource.data.dentistName is string
        && request.resource.data.dentistName.size() > 0
        && request.resource.data.procedureName is string
        && request.resource.data.procedureName.size() > 0
        && request.resource.data.status in ['SCHEDULED', 'CONFIRMED', 'COMPLETED', 'CANCELED']
        && (request.resource.data.notes == null || request.resource.data.notes is string)
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
    }

    function isValidSharedAppointment(clinicId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'clinicId',
          'userId',
          'date',
          'startTime',
          'durationMinutes',
          'patientName',
          'dentistName',
          'procedureName',
          'status',
          'notes',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id is string
        && request.resource.data.clinicId == clinicId
        && request.resource.data.userId is string
        && request.resource.data.date is string
        && request.resource.data.startTime is string
        && request.resource.data.durationMinutes is int
        && request.resource.data.durationMinutes >= 10
        && request.resource.data.durationMinutes <= 480
        && request.resource.data.patientName is string
        && request.resource.data.patientName.size() > 0
        && request.resource.data.dentistName is string
        && request.resource.data.dentistName.size() > 0
        && request.resource.data.procedureName is string
        && request.resource.data.procedureName.size() > 0
        && request.resource.data.status in ['SCHEDULED', 'CONFIRMED', 'COMPLETED', 'CANCELED']
        && (request.resource.data.notes == null || request.resource.data.notes is string)
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
    }

    function isValidFinancialEntry(userId, clinicId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'clinicId',
          'userId',
          'type',
          'status',
          'description',
          'category',
          'amountCents',
          'dueDate',
          'paidAt',
          'notes',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id is string
        && request.resource.data.clinicId == clinicId
        && request.resource.data.userId == userId
        && request.resource.data.type in ['INCOME', 'EXPENSE']
        && request.resource.data.status in ['OPEN', 'PAID', 'CANCELED']
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.category is string
        && request.resource.data.category.size() > 0
        && request.resource.data.amountCents is int
        && request.resource.data.amountCents > 0
        && request.resource.data.dueDate is string
        && (request.resource.data.paidAt == null || request.resource.data.paidAt is string)
        && (request.resource.data.notes == null || request.resource.data.notes is string)
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
    }

    function isValidSharedFinancialEntry(clinicId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'clinicId',
          'userId',
          'type',
          'status',
          'description',
          'category',
          'amountCents',
          'dueDate',
          'paidAt',
          'notes',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id is string
        && request.resource.data.clinicId == clinicId
        && request.resource.data.userId is string
        && request.resource.data.type in ['INCOME', 'EXPENSE']
        && request.resource.data.status in ['OPEN', 'PAID', 'CANCELED']
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.category is string
        && request.resource.data.category.size() > 0
        && request.resource.data.amountCents is int
        && request.resource.data.amountCents > 0
        && request.resource.data.dueDate is string
        && (request.resource.data.paidAt == null || request.resource.data.paidAt is string)
        && (request.resource.data.notes == null || request.resource.data.notes is string)
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
    }

    function isValidInventoryItem(userId, clinicId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'clinicId',
          'userId',
          'name',
          'category',
          'unit',
          'quantity',
          'minimumQuantity',
          'unitCostCents',
          'supplier',
          'status',
          'notes',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id is string
        && request.resource.data.clinicId == clinicId
        && request.resource.data.userId == userId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.category is string
        && request.resource.data.category.size() > 0
        && request.resource.data.unit is string
        && request.resource.data.unit.size() > 0
        && request.resource.data.quantity is int
        && request.resource.data.quantity >= 0
        && request.resource.data.minimumQuantity is int
        && request.resource.data.minimumQuantity >= 0
        && request.resource.data.unitCostCents is int
        && request.resource.data.unitCostCents >= 0
        && (request.resource.data.supplier == null || request.resource.data.supplier is string)
        && request.resource.data.status in ['ACTIVE', 'ARCHIVED']
        && (request.resource.data.notes == null || request.resource.data.notes is string)
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
    }

    function isValidSharedInventoryItem(clinicId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'clinicId',
          'userId',
          'name',
          'category',
          'unit',
          'quantity',
          'minimumQuantity',
          'unitCostCents',
          'supplier',
          'status',
          'notes',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id is string
        && request.resource.data.clinicId == clinicId
        && request.resource.data.userId is string
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.category is string
        && request.resource.data.category.size() > 0
        && request.resource.data.unit is string
        && request.resource.data.unit.size() > 0
        && request.resource.data.quantity is int
        && request.resource.data.quantity >= 0
        && request.resource.data.minimumQuantity is int
        && request.resource.data.minimumQuantity >= 0
        && request.resource.data.unitCostCents is int
        && request.resource.data.unitCostCents >= 0
        && (request.resource.data.supplier == null || request.resource.data.supplier is string)
        && request.resource.data.status in ['ACTIVE', 'ARCHIVED']
        && (request.resource.data.notes == null || request.resource.data.notes is string)
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
    }

    function isValidClinicSettings(userId, clinicId) {
      return request.resource.data.keys().hasOnly([
          'clinicId',
          'userId',
          'clinicName',
          'responsibleName',
          'phone',
          'email',
          'address',
          'timezone',
          'openingTime',
          'closingTime',
          'appointmentIntervalMinutes',
          'defaultAppointmentDurationMinutes',
          'notifyLowStock',
          'notifyOpenPayments',
          'notes',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.clinicId == clinicId
        && request.resource.data.userId == userId
        && request.resource.data.clinicName is string
        && request.resource.data.clinicName.size() > 0
        && request.resource.data.responsibleName is string
        && request.resource.data.responsibleName.size() > 0
        && request.resource.data.phone is string
        && request.resource.data.email is string
        && request.resource.data.address is string
        && request.resource.data.timezone in [
          'America/Sao_Paulo',
          'America/Cuiaba',
          'America/Manaus',
          'America/Rio_Branco'
        ]
        && request.resource.data.openingTime is string
        && request.resource.data.closingTime is string
        && request.resource.data.appointmentIntervalMinutes is int
        && request.resource.data.appointmentIntervalMinutes >= 10
        && request.resource.data.appointmentIntervalMinutes <= 120
        && request.resource.data.defaultAppointmentDurationMinutes is int
        && request.resource.data.defaultAppointmentDurationMinutes >= 10
        && request.resource.data.defaultAppointmentDurationMinutes <= 480
        && request.resource.data.notifyLowStock is bool
        && request.resource.data.notifyOpenPayments is bool
        && (request.resource.data.notes == null || request.resource.data.notes is string)
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
    }

    function isValidSharedClinicSettings(clinicId) {
      return request.resource.data.keys().hasOnly([
          'clinicId',
          'userId',
          'clinicName',
          'responsibleName',
          'cnpj',
          'phone',
          'email',
          'address',
          'timezone',
          'openingTime',
          'closingTime',
          'appointmentIntervalMinutes',
          'defaultAppointmentDurationMinutes',
          'notifyLowStock',
          'notifyOpenPayments',
          'notes',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.clinicId == clinicId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.clinicName is string
        && request.resource.data.clinicName.size() > 0
        && request.resource.data.responsibleName is string
        && request.resource.data.responsibleName.size() > 0
        && request.resource.data.cnpj is string
        && request.resource.data.cnpj.size() <= 18
        && request.resource.data.phone is string
        && request.resource.data.email is string
        && request.resource.data.address is string
        && request.resource.data.timezone in [
          'America/Sao_Paulo',
          'America/Cuiaba',
          'America/Manaus',
          'America/Rio_Branco'
        ]
        && request.resource.data.openingTime is string
        && request.resource.data.closingTime is string
        && request.resource.data.appointmentIntervalMinutes is int
        && request.resource.data.appointmentIntervalMinutes >= 10
        && request.resource.data.appointmentIntervalMinutes <= 120
        && request.resource.data.defaultAppointmentDurationMinutes is int
        && request.resource.data.defaultAppointmentDurationMinutes >= 10
        && request.resource.data.defaultAppointmentDurationMinutes <= 480
        && request.resource.data.notifyLowStock is bool
        && request.resource.data.notifyOpenPayments is bool
        && (request.resource.data.notes == null || request.resource.data.notes is string)
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
    }

    function isValidTeamMember(clinicId, memberId) {
      return request.resource.data.keys().hasOnly([
          'userId',
          'clinicId',
          'name',
          'email',
          'accessCode',
          'role',
          'status',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.userId == memberId
        && request.resource.data.clinicId == clinicId
        && request.resource.data.name is string
        && request.resource.data.email is string
        && (request.resource.data.accessCode == null || request.resource.data.accessCode is string)
        && request.resource.data.role in ['OWNER', 'ADMIN', 'RECEPTIONIST', 'DENTIST']
        && request.resource.data.status in ['ACTIVE', 'INACTIVE']
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
    }

    function isValidTeamInvite(clinicId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'clinicId',
          'email',
          'role',
          'status',
          'invitedByUserId',
          'invitedAt',
          'updatedAt'
        ])
        && request.resource.data.clinicId == clinicId
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.role in ['ADMIN', 'RECEPTIONIST', 'DENTIST']
        && request.resource.data.status in ['PENDING', 'CANCELED']
        && request.resource.data.invitedByUserId == request.auth.uid
        && request.resource.data.invitedAt is string
        && request.resource.data.updatedAt is string;
    }
  }
}
