  "info": {
    "title": "OdontoGest API",
    "description": "API REST versionada do OdontoGest. Não contém dados reais.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      },
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "__Secure-odontogest_refresh"
      }
    },
    "schemas": {
      "SignUpDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Marina Souza"
          },
          "email": {
            "type": "string",
            "example": "marina@exemplo.com.br"
          },
          "password": {
            "type": "string",
            "minLength": 12,
            "maxLength": 128,
            "writeOnly": true
          }
        },
        "required": [
          "name",
          "email",
          "password"
        ]
      },
      "MessageResponseDto": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        },
        "required": [
          "message"
        ]
      },
      "TokenDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "minLength": 40,
            "maxLength": 128,
            "writeOnly": true
          }
        },
        "required": [
          "token"
        ]
      },
      "FirebaseOnboardingDto": {
        "type": "object",
        "properties": {
          "idToken": {
            "type": "string",
            "minLength": 100,
            "maxLength": 4096,
            "writeOnly": true
          },
          "responsibleName": {
            "type": "string",
            "example": "Marina Souza"
          },
          "clinicName": {
            "type": "string",
            "example": "Clínica Sorriso"
          },
          "acceptTerms": {
            "type": "boolean",
            "example": true
          }
        },
        "required": [
          "idToken",
          "responsibleName",
          "clinicName",
          "acceptTerms"
        ]
      },
      "FirebaseOnboardingResponseDto": {
        "type": "object",
        "properties": {
          "clinicId": {
            "type": "string",
            "format": "uuid"
          },
          "created": {
            "type": "boolean"
          },
          "verificationRequired": {
            "type": "boolean",
            "enum": [
              true
            ]
          }
        },
        "required": [
          "clinicId",
          "created",
          "verificationRequired"
        ]
      },
      "FirebaseSessionDto": {
        "type": "object",
        "properties": {
          "idToken": {
            "type": "string",
            "minLength": 100,
            "maxLength": 4096,
            "writeOnly": true
          }
        },
        "required": [
          "idToken"
        ]
      },
      "AuthenticatedUserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          }
        },
        "required": [
          "id",
          "name",
          "email"
        ]
      },
      "ClinicSummaryResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "OWNER",
              "ADMIN",
              "DENTIST",
              "RECEPTIONIST",
              "FINANCE"
            ]
          }
        },
        "required": [
          "id",
          "name",
          "role"
        ]
      },
      "LoginResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/AuthenticatedUserResponseDto"
          },
          "clinics": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ClinicSummaryResponseDto"
            }
          },
          "activeClinicId": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          }
        },
        "required": [
          "accessToken",
          "user",
          "clinics",
          "activeClinicId"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "marina@exemplo.com.br"
          },
          "password": {
            "type": "string",
            "writeOnly": true
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "RefreshResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "activeClinicId": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          }
        },
        "required": [
          "accessToken",
          "activeClinicId"
        ]
      },
      "ForgotPasswordDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "marina@exemplo.com.br"
          }
        },
        "required": [
          "email"
        ]
      },
      "ResetPasswordDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "minLength": 40,
            "maxLength": 128,
            "writeOnly": true
          },
          "password": {
            "type": "string",
            "minLength": 12,
            "maxLength": 128,
            "writeOnly": true
          }
        },
        "required": [
          "token",
          "password"
        ]
      },
      "SelectActiveClinicDto": {
        "type": "object",
        "properties": {
          "clinicId": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": [
          "clinicId"
        ]
      },
      "ActiveClinicResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "activeClinicId": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": [
          "accessToken",
          "activeClinicId"
        ]
      },
      "SessionResponseDto": {
        "type": "object",
        "properties": {
          "familyId": {
            "type": "string",
            "format": "uuid"
          },
          "activeClinicId": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "issuedAt": {
            "format": "date-time",
            "type": "string"
          },
          "lastUsedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "idleExpiresAt": {
            "format": "date-time",
            "type": "string"
          },
          "absoluteExpiresAt": {
            "format": "date-time",
            "type": "string"
          },
          "ipPrefix": {
            "type": "string",
            "nullable": true
          },
          "userAgentSummary": {
            "type": "string",
            "nullable": true
          },
          "current": {
            "type": "boolean"
          }
        },
        "required": [
          "familyId",
          "activeClinicId",
          "issuedAt",
          "lastUsedAt",
          "idleExpiresAt",
          "absoluteExpiresAt",
          "ipPrefix",
          "userAgentSummary",
          "current"
        ]
      },
      "SessionsResponseDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SessionResponseDto"
            }
          }
        },
        "required": [
          "items"
        ]
      },
      "TenantContextResponseDto": {
        "type": "object",
        "properties": {
          "activeClinicId": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "roleCode": {
            "type": "string",
            "enum": [
              "OWNER",
              "ADMIN",
              "DENTIST",
              "RECEPTIONIST",
              "FINANCE"
            ],
            "nullable": true
          },
          "authorizationVersion": {
            "type": "number",
            "nullable": true
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "activeClinicId",
          "roleCode",
          "authorizationVersion",
          "permissions"
        ]
      },
      "CreatePatientDto": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "example": "Ana Paula Martins",
            "maxLength": 180
          },
          "cpf": {
            "type": "string",
            "example": "529.982.247-25"
          },
          "birthDate": {
            "type": "string",
            "example": "1990-05-20"
          },
          "phone": {
            "type": "string",
            "example": "(11) 99999-0000"
          },
          "whatsapp": {
            "type": "string",
            "example": "(11) 99999-0000"
          },
          "email": {
            "type": "string",
            "example": "ana@example.test"
          },
          "addressLine": {
            "type": "string",
            "maxLength": 500
          },
          "administrativeNotes": {
            "type": "string",
            "maxLength": 1000
          }
        },
        "required": [
          "fullName",
          "cpf"
        ]
      },
      "UpdatePatientDto": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "example": "Ana Paula Martins",
            "maxLength": 180
          },
          "cpf": {
            "type": "string",
            "example": "529.982.247-25"
          },
          "birthDate": {
            "type": "string",
            "example": "1990-05-20"
          },
          "phone": {
            "type": "string",
            "example": "(11) 99999-0000"
          },
          "whatsapp": {
            "type": "string",
            "example": "(11) 99999-0000"
          },
          "email": {
            "type": "string",
            "example": "ana@example.test"
          },
          "addressLine": {
            "type": "string",
            "maxLength": 500
          },
          "administrativeNotes": {
            "type": "string",
            "maxLength": 1000
          }
        }
      }
    }
  }
}