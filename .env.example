NODE_ENV=development
PORT=3000
APP_ORIGINS=http://localhost:4200
ORIGIN_CHECK_REQUIRED=true

# Firebase local usa emuladores. Em Vercel, remova os hosts de emulador e use
# credenciais protegidas no projeto da API.
FIREBASE_PROJECT_ID=demo-odontogest
FIREBASE_CLIENT_EMAIL=<FIREBASE_SERVICE_ACCOUNT_CLIENT_EMAIL>
FIREBASE_PRIVATE_KEY=<FIREBASE_SERVICE_ACCOUNT_PRIVATE_KEY_WITH_ESCAPED_NEWLINES>
FIREBASE_AUTH_CHECK_REVOKED=true
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
DATA_CONNECT_EMULATOR_HOST=127.0.0.1:9399

# Configuração pública do aplicativo Web Firebase. Não use credenciais Admin.
FIREBASE_WEB_API_KEY=<FIREBASE_WEB_API_KEY>
FIREBASE_WEB_AUTH_DOMAIN=<FIREBASE_PROJECT_ID>.firebaseapp.com
FIREBASE_WEB_APP_ID=<FIREBASE_WEB_APP_ID>

# Persistência Prisma legada durante a migração. Não será usada após a troca dos
# repositórios para o SQL Connect. Os placeholders não são credenciais reais.
DATABASE_URL=postgresql://odontogest_app:<APP_DB_PASSWORD>@localhost:5432/odontogest
MIGRATION_DATABASE_URL=postgresql://odontogest_owner:<OWNER_DB_PASSWORD>@localhost:5432/odontogest
POSTGRES_OWNER_PASSWORD=<OWNER_DB_PASSWORD>
ODONTOGEST_DB_APP_PASSWORD=<APP_DB_PASSWORD>
REDIS_PASSWORD=<REDIS_PASSWORD>
REDIS_URL=redis://default:<REDIS_PASSWORD>@localhost:6379/0

ACCESS_TOKEN_SECRET=<AT_LEAST_32_RANDOM_CHARACTERS>
ACCESS_TOKEN_TTL_SECONDS=300
REFRESH_TOKEN_IDLE_TTL_SECONDS=2592000
REFRESH_TOKEN_ABSOLUTE_TTL_SECONDS=7776000
COOKIE_SECURE=false
# Em produção, use __Secure-odontogest_refresh junto de COOKIE_SECURE=true.
COOKIE_NAME=odontogest_refresh

EMAIL_PROVIDER=fake
EMAIL_FROM=no-reply@localhost.invalid
SWAGGER_ENABLED=false
LOG_LEVEL=info
